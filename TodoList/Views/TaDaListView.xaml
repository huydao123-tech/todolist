<UserControl x:Class="TodoList.Views.TaDaListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance viewmodels:TaDaListViewModel}"
             Background="#FFFAF0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER: Mừng chiến thắng -->
        <Border Grid.Row="0" Background="#FBBF24" Padding="40,30" CornerRadius="0,0,30,30">
            <StackPanel HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="TrophyVariantOutline" Width="80" Height="80" 
                                         Foreground="#B45309" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <TextBlock Text="TA-DA! BẢNG VÀNG THÀNH TÍCH" 
                           FontSize="32" FontWeight="Black" Foreground="#78350F" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <!-- Số lượng hoàn thành khổng lồ -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Bạn đã chém đẹp " FontSize="20" FontWeight="SemiBold" Foreground="#92400E" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="48" FontWeight="Black" Foreground="#78350F" Margin="10,0"/>
                    <TextBlock Text=" việc trong ngày hôm nay!" FontSize="20" FontWeight="SemiBold" Foreground="#92400E" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Lời động viên -->
                <Border Background="#FEF3C7" CornerRadius="12" Padding="20,10" Margin="0,20,0,0">
                    <TextBlock Text="{Binding EncouragingMessage}" 
                               FontSize="16" FontWeight="Bold" Foreground="#D97706" 
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- LIST: Các huân chương -->
        <ScrollViewer Grid.Row="1" Margin="40,30,40,20" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CompletedTasks}">
                <!-- Panel dưới dạng lưới -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <!-- Item Template giống tấm huân chương -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="300" Height="100" Margin="15" Background="White" CornerRadius="16" Padding="15">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Color="#FDE68A" Opacity="0.8"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <materialDesign:PackIcon Grid.Column="0" Kind="CheckDecagram" Width="40" Height="40" 
                                                         Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#1F2024" TextWrapping="Wrap"/>
                                    <TextBlock Text="Đã hoàn thành xuất sắc!" FontSize="12" Foreground="#059669" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
