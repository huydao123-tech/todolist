<UserControl x:Class="TodoList.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewmodels:DashboardViewModel}"
             d:DesignHeight="800" d:DesignWidth="950">
    <UserControl.Resources>
        <local:StatusToBoolConverter xmlns:local="clr-namespace:TodoList.Converters" x:Key="StatusToBoolConverter" />
    </UserControl.Resources>
    
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Grid Grid.Row="0" Margin="0,0,0,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <!-- Search Bar -->
            <Border Background="White" CornerRadius="8" Padding="15,8" HorizontalAlignment="Left" Width="350">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Magnify" Foreground="#A0A0A0" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox materialDesign:HintAssist.Hint="Search tasks..." BorderThickness="0" Width="300" Background="Transparent"/>
                </StackPanel>
            </Border>
            
            <!-- Profile & Notif -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#1F2024" Height="40" Margin="0,0,10,0" Padding="10,0"
                        Command="{Binding SyncGoogleCalendarCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Google" Width="20" Height="20" Margin="0,0,5,0" />
                        <TextBlock Text="Sync" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <materialDesign:PackIcon Kind="BellOutline" Width="24" Height="24" Foreground="#1F2024" Margin="0,0,20,0" VerticalAlignment="Center" />
                <Ellipse Width="40" Height="40" Fill="#D1D5DB" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Elena Thorne" FontWeight="Bold" FontSize="14" />
                    <TextBlock Text="Pro Account" FontSize="11" Foreground="#8B8D98" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Title Section & Tabs -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="{Binding TitleText}" FontSize="32" FontWeight="Bold" Foreground="#1F2024" />
            <TextBlock Text="{Binding SubTitleText}" FontSize="14" Foreground="#8B8D98" Margin="0,5,0,0" />
            
            <!-- Tabs cho Today và All Tasks -->
            <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="0,15,0,0" 
                        Background="Transparent" BorderThickness="0" Padding="0">
                <TabItem Header="Today" />
                <TabItem Header="All Tasks" />
            </TabControl>
        </StackPanel>

        <!-- Main Layout (2 Columns) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Task List -->
            <ListBox Grid.Column="0" ItemsSource="{Binding DisplayedTasks}" Background="Transparent" BorderThickness="0" Margin="0,0,30,0"
                     HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,15"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          IsChecked="{Binding Status, Converter={StaticResource StatusToBoolConverter}}">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#1F2024" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{Binding Priority, Converter={StaticResource PriorityToBg}, FallbackValue=#E0DDF7}" 
                                                    CornerRadius="10" Padding="8,2" Margin="0,0,15,0">
                                                <TextBlock Text="{Binding Priority, FallbackValue=General}" FontSize="11" FontWeight="Bold" 
                                                           Foreground="{Binding Priority, Converter={StaticResource PriorityToFg}, FallbackValue=#5E40DF}"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ClockOutline" Width="12" Height="12" Foreground="#8B8D98" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding TimeRangeDisplay}" FontSize="12" Foreground="#8B8D98"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                Foreground="#8B8D98" Width="30" Height="30" Padding="0" Margin="0,0,5,0"
                                                ToolTip="View Details"
                                                Command="{Binding DataContext.ShowTaskDetailsCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="EyeOutline" Width="20" Height="20" />
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                Foreground="#EF4444" Width="30" Height="30" Padding="0"
                                                ToolTip="Delete Task"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="20" Height="20" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Right Column Widgets -->
            <StackPanel Grid.Column="1">
                <!-- Daily Productivity -->
                <Border Background="#5E40DF" CornerRadius="16" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Daily Productivity" Foreground="White" FontWeight="SemiBold" />
                            <materialDesign:PackIcon Kind="TrendingUp" Foreground="White" HorizontalAlignment="Right" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="75%" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Almost there!" Foreground="#D1D5DB" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                        </StackPanel>
                        <ProgressBar Value="75" Height="6" Background="#4A30B5" Foreground="White" materialDesign:TransitionAssist.DisableTransitions="True" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Quick Add Widget for Testing -->
                <Border Background="White" CornerRadius="16" Padding="20" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Quick Add Task" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBox materialDesign:HintAssist.Hint="Press Enter to add" Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,10">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding AddQuickTaskCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
