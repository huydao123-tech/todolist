<UserControl x:Class="TodoList.Views.TaskDetailDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewmodels:TaskDetailDialogViewModel}"
             Width="400" Background="White">
    <UserControl.Resources>
        <local:PriorityToBackgroundConverter xmlns:local="clr-namespace:TodoList.Converters" x:Key="PriorityToBg"/>
        <local:PriorityToForegroundConverter xmlns:local="clr-namespace:TodoList.Converters" x:Key="PriorityToFg"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header: Priority and Close Button -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Border CornerRadius="8" Padding="10,4" HorizontalAlignment="Left"
                    Background="{Binding TaskItem.Priority, Converter={StaticResource PriorityToBg}}">
                <TextBlock Text="{Binding TaskItem.Priority}" FontSize="12" FontWeight="Bold"
                           Foreground="{Binding TaskItem.Priority, Converter={StaticResource PriorityToFg}}"/>
            </Border>
            
            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                    HorizontalAlignment="Right" Padding="0" Width="24" Height="24"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20" Foreground="#8B8D98"/>
            </Button>
        </Grid>
        
        <!-- Title & Time -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="{Binding TaskItem.Title}" FontSize="24" FontWeight="Bold" Foreground="#1F2024" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ClockOutline" Width="16" Height="16" Foreground="#8B8D98" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding TaskItem.TimeRangeDisplay}" FontSize="14" Foreground="#8B8D98" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Description -->
        <StackPanel Grid.Row="2" Margin="0,0,0,30">
            <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="Bold" Foreground="#8B8D98" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding TaskItem.Description, TargetNullValue='No description provided.', FallbackValue='No description provided.'}" 
                       FontSize="14" Foreground="#1F2024" TextWrapping="Wrap" />
        </StackPanel>
        
        <!-- Action Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding EditTaskCommand}"
                    Foreground="#5E40DF" BorderBrush="#5E40DF"
                    Height="42" materialDesign:ButtonAssist.CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Pencil" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Edit" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            
            <Button Grid.Column="2" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding DeleteTaskCommand}"
                    Foreground="#DC2626" BorderBrush="#DC2626"
                    Height="42" materialDesign:ButtonAssist.CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="TrashCan" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Delete" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
