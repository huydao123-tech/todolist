<Window x:Class="TodoList.Views.MainShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
        xmlns:views="clr-namespace:TodoList.Views"
        xmlns:converters="clr-namespace:TodoList.Converters"
        mc:Ignorable="d"
        Title="Tasks" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA"
        d:DataContext="{d:DesignInstance viewmodels:MainViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:ViewModelToVisibilityConverter x:Key="ViewModelToVisibilityConverter" />
        
        <!-- DataTemplates to swap Login & Register views inside ContentControl -->
        <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>
    </Window.Resources>
    
    <materialDesign:DialogHost Identifier="MainDialogHost" DialogTheme="Inherit">
        <Grid>
            <!-- Auth Screen (Visible when not logged in) -->
            <ContentControl Content="{Binding CurrentAuthViewModel}"
                            Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBooleanToVisibilityConverter}, FallbackValue=Visible}"/>

            <!-- App Dashboard Shell (Visible when logged in) -->
            <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="#F0F1F5" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                            <materialDesign:PackIcon Kind="CheckboxMarkedCircle" Width="30" Height="30" Foreground="#5E40DF"/>
                            <TextBlock Text="Tasks" FontSize="24" FontWeight="Bold" Foreground="#5E40DF" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Navigation -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,30">
                            <TextBlock Text="DASHBOARD" FontSize="12" FontWeight="SemiBold" Foreground="#8B8D98" Margin="0,0,0,10" />
                            
                            <!-- Today -->
                            <Button HorizontalContentAlignment="Left" Margin="0,2" Command="{Binding NavigateToTodayCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                        <Setter Property="Foreground" Value="#1F2024"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="Today">
                                                <Setter Property="Background" Value="#E0DDF7"/>
                                                <Setter Property="Foreground" Value="#5E40DF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CalendarToday" Width="20" Height="20" Margin="0,0,15,0"/>
                                    <TextBlock Text="Today" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Calendar -->
                            <Button HorizontalContentAlignment="Left" Margin="0,2" Command="{Binding NavigateToCalendarCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                        <Setter Property="Foreground" Value="#1F2024"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="Calendar">
                                                <Setter Property="Background" Value="#E0DDF7"/>
                                                <Setter Property="Foreground" Value="#5E40DF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CalendarMonth" Width="20" Height="20" Margin="0,0,15,0"/>
                                    <TextBlock Text="Calendar" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <!-- Eisenhower Matrix -->
                            <Button HorizontalContentAlignment="Left" Margin="0,2" Command="{Binding NavigateToEisenhowerCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                        <Setter Property="Foreground" Value="#1F2024"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="Eisenhower">
                                                <Setter Property="Background" Value="#E0DDF7"/>
                                                <Setter Property="Foreground" Value="#5E40DF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewGrid" Width="20" Height="20" Margin="0,0,15,0"/>
                                    <TextBlock Text="Eisenhower" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <!-- Mind Sandbox (Idea Dump) -->
                            <Button HorizontalContentAlignment="Left" Margin="0,2" Command="{Binding NavigateToMindSandboxCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                        <Setter Property="Foreground" Value="#1F2024"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="MindSandbox">
                                                <Setter Property="Background" Value="#E0DDF7"/>
                                                <Setter Property="Foreground" Value="#5E40DF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="LightbulbOn" Width="20" Height="20" Margin="0,0,15,0"/>
                                    <TextBlock Text="Mind Sandbox" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <!-- Ta-Da List -->
                            <Button HorizontalContentAlignment="Left" Margin="0,2" Command="{Binding NavigateToTaDaListCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                        <Setter Property="Foreground" Value="#1F2024"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="TaDaList">
                                                <Setter Property="Background" Value="#FDE68A"/>
                                                <Setter Property="Foreground" Value="#B45309"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="StarShootingOutline" Width="20" Height="20" Margin="0,0,15,0"/>
                                    <TextBlock Text="Ta-Da List" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Categories -->
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="CATEGORIES" FontSize="12" FontWeight="SemiBold" Foreground="#8B8D98" Margin="0,0,0,10" />
                            <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalContentAlignment="Left" Foreground="#1F2024" Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#1A73E8" Margin="5,0,22,0" />
                                    <TextBlock Text="Personal" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalContentAlignment="Left" Foreground="#1F2024" Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#D97706" Margin="5,0,22,0" />
                                    <TextBlock Text="Work" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalContentAlignment="Left" Foreground="#1F2024" Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#5E40DF" Margin="5,0,22,0" />
                                    <TextBlock Text="Study" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalContentAlignment="Left" Foreground="#1F2024" Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#DC2626" Margin="5,0,22,0" />
                                    <TextBlock Text="Health" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- User Profile Info & Actions -->
                        <StackPanel Grid.Row="3">
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,15,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="36" Height="36" Fill="#5E40DF" Margin="0,0,10,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Current User" FontSize="11" Foreground="#8B8D98"/>
                                        <TextBlock Text="{Binding CurrentUserEmail}" FontSize="13" FontWeight="Bold" Foreground="#1F2024" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconForegroundButton}" Width="30" Height="30" Padding="0"
                                            Command="{Binding LogoutCommand}" ToolTip="Log Out">
                                        <materialDesign:PackIcon Kind="Logout" Width="18" Height="18" Foreground="#EF4444"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Sync Progress Indicator -->
                            <Border Padding="5,8" CornerRadius="8" Margin="0,0,0,8" Background="#EDE9FD"
                                    Visibility="{Binding IsSyncing, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True"
                                                 Width="16" Height="16" Foreground="#5E40DF" Margin="0,0,8,0"/>
                                    <TextBlock Text="Syncing Google Calendar..." FontSize="11" Foreground="#5E40DF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- New Task Button -->
                            <Button Background="#5E40DF" Foreground="White" BorderThickness="0" Height="45"
                                    materialDesign:ButtonAssist.CornerRadius="10"
                                    Command="{Binding NavigateToCreateTaskCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Margin="0,0,5,0" />
                                    <TextBlock Text="New Task" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content (Cached via Visibility to prevent Lag/Memory leaks) -->
                <Grid Grid.Column="1">
                    <views:DashboardView DataContext="{Binding DashboardViewModel}" 
                                         Visibility="{Binding DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModelToVisibilityConverter}, ConverterParameter=DashboardViewModel}" />
                    <views:CalendarView DataContext="{Binding CalendarViewModel}" 
                                        Visibility="{Binding DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModelToVisibilityConverter}, ConverterParameter=CalendarViewModel}" />
                    <views:CreateTaskView DataContext="{Binding CreateTaskViewModel}" 
                                          Visibility="{Binding DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModelToVisibilityConverter}, ConverterParameter=CreateTaskViewModel}" />
                    <views:EisenhowerView DataContext="{Binding EisenhowerViewModel}" 
                                          Visibility="{Binding DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModelToVisibilityConverter}, ConverterParameter=EisenhowerViewModel}" />
                    <views:MindSandboxView DataContext="{Binding MindSandboxViewModel}" 
                                           Visibility="{Binding DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModelToVisibilityConverter}, ConverterParameter=MindSandboxViewModel}" />
                    <views:TaDaListView DataContext="{Binding TaDaListViewModel}" 
                                        Visibility="{Binding DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModelToVisibilityConverter}, ConverterParameter=TaDaListViewModel}" />
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
