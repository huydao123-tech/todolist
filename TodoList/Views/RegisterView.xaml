<UserControl x:Class="TodoList.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
             xmlns:converters="clr-namespace:TodoList.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewmodels:RegisterViewModel}"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F5F6FA">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Branding Side -->
            <ColumnDefinition Width="1.2*" />
            <!-- Right Form Side -->
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Left Branding Panel with Gradient -->
        <Border Grid.Column="0" CornerRadius="0,30,30,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A26C1" Offset="0.0"/>
                    <GradientStop Color="#7C5EF2" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="60">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo -->
                <StackPanel Orientation="Horizontal" Grid.Row="0">
                    <materialDesign:PackIcon Kind="CheckboxMarkedCircle" Width="36" Height="36" Foreground="White"/>
                    <TextBlock Text="Tasks" FontSize="28" FontWeight="Bold" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Branding Text -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Join Us" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <TextBlock Text="Create your account to start managing your daily workflow, collaborating, and tracking your metrics." 
                               FontSize="18" Foreground="#D2C8FB" TextWrapping="Wrap" LineHeight="26"/>
                </StackPanel>

                <!-- Branding Footer -->
                <TextBlock Grid.Row="2" Text="© 2026 Tasks App. All rights reserved." FontSize="12" Foreground="#A99BF7" />
            </Grid>
        </Border>

        <!-- Right Form Panel -->
        <Grid Grid.Column="1" Margin="80,0" VerticalAlignment="Center">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="Sign Up" FontSize="36" FontWeight="Bold" Foreground="#1F2024" Margin="0,0,0,10"/>
                <TextBlock Text="Create a new workspace account" FontSize="14" Foreground="#8B8D98" Margin="0,0,0,30"/>

                <!-- Error Message -->
                <Border Background="#FEE2E2" CornerRadius="8" Padding="15,10" Margin="0,0,0,20"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#EF4444" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Input Fields -->
                <!-- Email -->
                <TextBlock Text="EMAIL ADDRESS" FontSize="11" FontWeight="Bold" Foreground="#8B8D98" Margin="0,0,0,8"/>
                <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15,5" Margin="0,0,0,20">
                    <TextBox materialDesign:HintAssist.Hint="yourname@domain.com" 
                             BorderThickness="0" 
                             FontSize="15" 
                             Background="Transparent"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="PASSWORD (MIN 6 CHARS)" FontSize="11" FontWeight="Bold" Foreground="#8B8D98" Margin="0,0,0,8"/>
                <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15,5" Margin="0,0,0,20">
                    <PasswordBox x:Name="TxtPassword" 
                                 materialDesign:HintAssist.Hint="••••••••" 
                                 BorderThickness="0" 
                                 FontSize="15" 
                                 Background="Transparent"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                </Border>

                <!-- Confirm Password -->
                <TextBlock Text="CONFIRM PASSWORD" FontSize="11" FontWeight="Bold" Foreground="#8B8D98" Margin="0,0,0,8"/>
                <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15,5" Margin="0,0,0,30">
                    <PasswordBox x:Name="TxtConfirmPassword" 
                                 materialDesign:HintAssist.Hint="••••••••" 
                                 BorderThickness="0" 
                                 FontSize="15" 
                                 Background="Transparent"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                </Border>

                <!-- Register Button -->
                <Button Background="#5E40DF" Foreground="White" BorderThickness="0" Height="50" FontSize="16" FontWeight="Bold"
                        materialDesign:ButtonAssist.CornerRadius="10" Margin="0,0,0,20"
                        Command="{Binding RegisterCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Sign Up" VerticalAlignment="Center" Visibility="{Binding IsBusy, Converter={StaticResource InverseBooleanToVisibilityConverter}, FallbackValue=Visible}"/>
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" 
                                     Width="24" Height="24" Foreground="White"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>
                    </StackPanel>
                </Button>

                <!-- Redirect to Login -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Already have an account? " Foreground="#8B8D98" FontSize="14"/>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Margin="5,0,0,0" Height="Auto" VerticalAlignment="Center"
                            Command="{Binding NavigateToLoginCommand}" Foreground="#5E40DF" FontSize="14" FontWeight="Bold">
                        <TextBlock Text="Log In"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
