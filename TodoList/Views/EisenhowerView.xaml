<UserControl x:Class="TodoList.Views.EisenhowerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance viewmodels:EisenhowerViewModel}"
             d:DesignHeight="900" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- ── Task Card inside a quadrant ── -->
        <DataTemplate x:Key="QuadrantTaskTemplate">
            <Border Background="White" CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                    BorderBrush="#E2E8F0" BorderThickness="1"
                    Effect="{DynamicResource MaterialDesignShadowDepth1}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Done checkbox -->
                    <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                              Style="{StaticResource MaterialDesignCheckBox}"
                              IsChecked="{Binding Status, Converter={StaticResource StatusToBoolConverter}}"
                              Command="{Binding DataContext.ToggleDoneCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                              CommandParameter="{Binding}"/>

                    <!-- Title + DueDate -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#1F2024" TextTrimming="CharacterEllipsis" MaxWidth="180">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="DONE">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="#9CA3AF" Margin="0,2,0,0"
                                   Text="{Binding DueDate, StringFormat='{}{0:dd/MM/yyyy}', TargetNullValue='Chưa có lịch'}"/>
                    </StackPanel>

                    <!-- Delete button -->
                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Foreground="#EF4444" Width="28" Height="28" Padding="0"
                            ToolTip="Xóa"
                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}">
                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"/>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ── Move Button style ── -->
        <Style x:Key="MoveBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="3,2"/>
        </Style>
    </UserControl.Resources>

    <!-- ══════════════════════════════════════════ ROOT ══════════════════════════════════════════ -->
    <Grid Background="#F5F5FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- P2 Suggestion Banner -->
            <RowDefinition Height="Auto"/>  <!-- Tabs -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" Margin="30,30,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Eisenhower Matrix" FontSize="30" FontWeight="Bold" Foreground="#1F2024"/>
                <TextBlock Text="Phân loại công việc theo Mức độ Quan trọng &amp; Khẩn cấp để tối ưu thời gian"
                           FontSize="13" Foreground="#8B8D98" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- P1 WIP Badge -->
            <Border Grid.Column="1" CornerRadius="10" Padding="14,8" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#DCFCE7"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsP1Overloaded}" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Foreground" Value="#16A34A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsP1Overloaded}" Value="True">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Ô P1 bình thường"/>
                                <Setter Property="Foreground" Value="#16A34A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsP1Overloaded}" Value="True">
                                        <Setter Property="Text" Value="⚠ Ô P1 Quá tải!"/>
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding P1CountLabel}" FontSize="13" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#16A34A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsP1Overloaded}" Value="True">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ P2 SUGGESTION BANNER ══ -->
        <Border Grid.Row="1" Margin="30,0,30,10" CornerRadius="10" Background="#EFF6FF" Padding="16,12"
                Visibility="{Binding HasP2Suggestion, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding P2SuggestionText}" FontSize="13" Foreground="#1D4ED8" 
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Margin="10,0,5,0" Background="#2563EB" Foreground="White"
                        BorderThickness="0" Height="32" Padding="12,0" FontSize="12" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Command="{Binding AcceptP2SuggestionCommand}"
                        Content="✅ Đặt lịch ngay"/>
                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Foreground="#9CA3AF" Width="28" Height="28" Padding="0"
                        Command="{Binding DismissP2SuggestionCommand}" ToolTip="Bỏ qua">
                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                </Button>
            </Grid>
        </Border>

        <!-- ══ TABS ══ -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex}"
                    Margin="30,0,30,10" Background="Transparent" BorderThickness="0" Padding="0">
            <TabItem Header="🧩  Ma trận"/>
            <TabItem Header="📊  Analytics"/>
        </TabControl>

        <!-- ══════════════════ TAB 0: MATRIX VIEW ══════════════════ -->
        <Grid Grid.Row="3" Margin="30,0,30,30">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>  <!-- Inbox sidebar -->
                <ColumnDefinition Width="*"/>   <!-- 2x2 Matrix -->
            </Grid.ColumnDefinitions>

            <!-- ── INBOX / BRAIN DUMP ── -->
            <Border Grid.Column="0" Background="White" CornerRadius="14" Margin="0,0,16,0"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#F5F5FA" CornerRadius="14,14,0,0" Padding="16,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="InboxArrowDown" Width="20" Height="20" Foreground="#5E40DF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Brain Dump" FontSize="15" FontWeight="Bold" Foreground="#1F2024" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Ghi nhanh — phân loại sau" FontSize="11" Foreground="#8B8D98"/>
                        </StackPanel>
                    </Border>

                    <!-- Input -->
                    <Border Grid.Row="1" Padding="12,10" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Thêm việc vào Inbox..."
                                     Text="{Binding NewInboxTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" BorderThickness="0" Background="Transparent">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding AddToInboxCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}"
                                    Foreground="#5E40DF" Width="30" Height="30" Padding="0"
                                    Command="{Binding AddToInboxCommand}" ToolTip="Thêm (Enter)">
                                <materialDesign:PackIcon Kind="PlusCircle" Width="22" Height="22"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Inbox List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding InboxTasks}" Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1F2024" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <!-- Move buttons: 4 commands riêng biệt cho từng ô -->
                                            <UniformGrid Columns="2" Rows="2">
                                                <Button Style="{StaticResource MoveBtn}" BorderBrush="#FCA5A5" Foreground="#DC2626"
                                                        Content="🔴 P1 Do"
                                                        Command="{Binding DataContext.MoveToP1Command, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource MoveBtn}" BorderBrush="#86EFAC" Foreground="#16A34A"
                                                        Content="🟢 P2 Plan"
                                                        Command="{Binding DataContext.MoveToP2Command, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource MoveBtn}" BorderBrush="#FDE68A" Foreground="#D97706"
                                                        Content="🟡 P3 Delegate"
                                                        Command="{Binding DataContext.MoveToP3Command, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource MoveBtn}" BorderBrush="#D1D5DB" Foreground="#6B7280"
                                                        Content="⚪ P4 Drop"
                                                        Command="{Binding DataContext.MoveToP4Command, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── 2x2 MATRIX ── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Axis Labels Row -->
                <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔥 Quan trọng" HorizontalAlignment="Center"
                               FontSize="12" FontWeight="Bold" Foreground="#DC2626"/>
                    <TextBlock Grid.Column="1" Text="⬜ Không quan trọng" HorizontalAlignment="Center"
                               FontSize="12" FontWeight="Bold" Foreground="#6B7280"/>
                </Grid>

                <!-- ══ P1: Do (Đỏ - Quan trọng & Khẩn cấp) ══ -->
                <Border Grid.Row="1" Grid.Column="0" CornerRadius="14" Margin="0,0,8,8"
                        Background="#FFF5F5" BorderBrush="#FECACA" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#FEE2E2" CornerRadius="12,12,0,0" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="🔴  P1 — Do" FontSize="15" FontWeight="Bold" Foreground="#991B1B"/>
                                    <TextBlock Text="Quan trọng &amp; Khẩn cấp → Làm ngay" FontSize="11" Foreground="#DC2626"/>
                                </StackPanel>
                                <!-- WIP counter -->
                                <Border Grid.Column="1" CornerRadius="20" Padding="10,4" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsP1Overloaded}" Value="True">
                                                    <Setter Property="Background" Value="#991B1B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding P1CountLabel}" FontWeight="Bold" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsP1Overloaded}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4">
                            <ListBox ItemsSource="{Binding P1Tasks}" Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ItemTemplate="{StaticResource QuadrantTaskTemplate}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ══ P3: Delegate (Vàng - Không quan trọng & Khẩn cấp) ══ -->
                <Border Grid.Row="1" Grid.Column="1" CornerRadius="14" Margin="8,0,0,8"
                        Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#FEF3C7" CornerRadius="12,12,0,0" Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="🟡  P3 — Delegate" FontSize="15" FontWeight="Bold" Foreground="#92400E"/>
                                <TextBlock Text="Không quan trọng &amp; Khẩn cấp → Ủy quyền" FontSize="11" Foreground="#D97706"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4">
                            <ListBox ItemsSource="{Binding P3Tasks}" Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ItemTemplate="{StaticResource QuadrantTaskTemplate}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ══ P2: Schedule (Xanh - Quan trọng & Không khẩn cấp) ══ -->
                <Border Grid.Row="2" Grid.Column="0" CornerRadius="14" Margin="0,8,8,0"
                        Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#DCFCE7" CornerRadius="12,12,0,0" Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="🟢  P2 — Schedule" FontSize="15" FontWeight="Bold" Foreground="#166534"/>
                                <TextBlock Text="Quan trọng &amp; Không khẩn cấp → Lên lịch" FontSize="11" Foreground="#16A34A"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4">
                            <ListBox ItemsSource="{Binding P2Tasks}" Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ItemTemplate="{StaticResource QuadrantTaskTemplate}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ══ P4: Eliminate (Xám - Không quan trọng & Không khẩn cấp) ══ -->
                <Border Grid.Row="2" Grid.Column="1" CornerRadius="14" Margin="8,8,0,0"
                        Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#F3F4F6" CornerRadius="12,12,0,0" Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="⚪  P4 — Eliminate" FontSize="15" FontWeight="Bold" Foreground="#374151"/>
                                <TextBlock Text="Không quan trọng &amp; Không khẩn cấp → Loại bỏ" FontSize="11" Foreground="#6B7280"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4">
                            <ListBox ItemsSource="{Binding P4Tasks}" Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ItemTemplate="{StaticResource QuadrantTaskTemplate}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Axis Labels Column (Khẩn cấp / Không khẩn cấp) - Rotated -->
                <StackPanel Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                            IsHitTestVisible="False" VerticalAlignment="Stretch" HorizontalAlignment="Left"
                            Width="20" Margin="-30,0,0,0">
                    <TextBlock Text="⚡ Khẩn cấp" FontSize="11" FontWeight="Bold" Foreground="#DC2626"
                               RenderTransformOrigin="0.5,0.5" Margin="0,60,0,0">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="-90"/>
                        </TextBlock.LayoutTransform>
                    </TextBlock>
                    <TextBlock Text="🕰 Không khẩn cấp" FontSize="11" FontWeight="Bold" Foreground="#6B7280"
                               RenderTransformOrigin="0.5,0.5" Margin="0,100,0,0">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="-90"/>
                        </TextBlock.LayoutTransform>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ══════════════════ TAB 1: ANALYTICS VIEW ══════════════════ -->
        <ScrollViewer Grid.Row="3" Margin="30,0,30,30" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel>

                <!-- ── Summary Cards Row ── -->
                <UniformGrid Columns="5" Margin="0,0,0,24">
                    <!-- Total Done -->
                    <Border Background="White" CornerRadius="12" Padding="18,16" Margin="0,0,12,0"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Tổng hoàn thành" FontSize="12" Foreground="#8B8D98" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding TotalDone}" FontSize="28" FontWeight="Bold" Foreground="#5E40DF"/>
                        </StackPanel>
                    </Border>
                    <!-- P1 Done -->
                    <Border Background="#FFF5F5" CornerRadius="12" Padding="18,16" Margin="0,0,12,0"
                            BorderBrush="#FECACA" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🔴 P1 Done" FontSize="12" Foreground="#DC2626" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding P1Done}" FontSize="28" FontWeight="Bold" Foreground="#991B1B"/>
                        </StackPanel>
                    </Border>
                    <!-- P2 Done -->
                    <Border Background="#F0FDF4" CornerRadius="12" Padding="18,16" Margin="0,0,12,0"
                            BorderBrush="#86EFAC" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🟢 P2 Done" FontSize="12" Foreground="#16A34A" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding P2Done}" FontSize="28" FontWeight="Bold" Foreground="#166534"/>
                        </StackPanel>
                    </Border>
                    <!-- P3 Done -->
                    <Border Background="#FFFBEB" CornerRadius="12" Padding="18,16" Margin="0,0,12,0"
                            BorderBrush="#FDE68A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🟡 P3 Done" FontSize="12" Foreground="#D97706" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding P3Done}" FontSize="28" FontWeight="Bold" Foreground="#92400E"/>
                        </StackPanel>
                    </Border>
                    <!-- P4 Done -->
                    <Border Background="#F9FAFB" CornerRadius="12" Padding="18,16"
                            BorderBrush="#D1D5DB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚪ P4 Done" FontSize="12" Foreground="#6B7280" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding P4Done}" FontSize="28" FontWeight="Bold" Foreground="#374151"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ── Distribution Chart ── -->
                <Border Background="White" CornerRadius="14" Padding="24" Margin="0,0,0,20"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Phân bổ công việc theo ô" FontSize="16" FontWeight="Bold"
                                   Foreground="#1F2024" Margin="0,0,0,20"/>

                        <!-- P1 Bar -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔴 P1 — Do" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#DC2626"/>
                            <ProgressBar Grid.Column="1" Value="{Binding P1Count}" Maximum="{Binding TotalActive}"
                                         Height="12" Foreground="#EF4444" Background="#F3F4F6"
                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                         materialDesign:TransitionAssist.DisableTransitions="True"/>
                            <TextBlock Grid.Column="2" Text="{Binding P1Count}" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- P2 Bar -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🟢 P2 — Schedule" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#16A34A"/>
                            <ProgressBar Grid.Column="1" Value="{Binding P2Count}" Maximum="{Binding TotalActive}"
                                         Height="12" Foreground="#16A34A" Background="#F3F4F6"
                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                         materialDesign:TransitionAssist.DisableTransitions="True"/>
                            <TextBlock Grid.Column="2" Text="{Binding P2Count}" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="Bold" Foreground="#16A34A" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- P3 Bar -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🟡 P3 — Delegate" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#D97706"/>
                            <ProgressBar Grid.Column="1" Value="{Binding P3Count}" Maximum="{Binding TotalActive}"
                                         Height="12" Foreground="#F59E0B" Background="#F3F4F6"
                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                         materialDesign:TransitionAssist.DisableTransitions="True"/>
                            <TextBlock Grid.Column="2" Text="{Binding P3Count}" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- P4 Bar -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⚪ P4 — Eliminate" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#6B7280"/>
                            <ProgressBar Grid.Column="1" Value="{Binding P4Count}" Maximum="{Binding TotalActive}"
                                         Height="12" Foreground="#6B7280" Background="#F3F4F6"
                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                         materialDesign:TransitionAssist.DisableTransitions="True"/>
                            <TextBlock Grid.Column="2" Text="{Binding P4Count}" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── AI Advice Card ── -->
                <Border CornerRadius="14" Padding="24"
                        BorderBrush="#C4B5FD" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#EDE9FE" Offset="0"/>
                            <GradientStop Color="#E0F2FE" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding AnalyticsAdviceIcon}" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Lời khuyên từ Chuyên gia" FontSize="16" FontWeight="Bold"
                                       Foreground="#3730A3" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AnalyticsAdvice}" FontSize="14" Foreground="#1E1B4B"
                                   TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                </Border>

                <!-- ── Eisenhower Tips ── -->
                <Border Background="White" CornerRadius="14" Padding="24" Margin="0,20,0,0"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💡 Bí quyết áp dụng hiệu quả" FontSize="16" FontWeight="Bold"
                                   Foreground="#1F2024" Margin="0,0,0,16"/>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="🎯 Tối ưu hóa ô P2" FontWeight="Bold" FontSize="13" Foreground="#166534"/>
                            <TextBlock Text="Càng dành nhiều thời gian lập kế hoạch ở P2 (bảo trì, học kỹ năng, phòng ngừa sớm), bạn sẽ càng ít gặp khủng hoảng ở P1."
                                       FontSize="12" Foreground="#374151" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="📏 Giới hạn số lượng việc" FontWeight="Bold" FontSize="13" Foreground="#92400E"/>
                            <TextBlock Text="Mỗi ô chỉ nên để tối đa 7–8 công việc để tránh bị ngợp. Ô P1 chúng tôi giới hạn ở mức 5 để bảo vệ sức khỏe tinh thần của bạn."
                                       FontSize="12" Foreground="#374151" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="🤔 Câu hỏi cốt lõi" FontWeight="Bold" FontSize="13" Foreground="#3730A3"/>
                            <TextBlock Text="Hỏi bản thân: &quot;Mình làm việc này vì mục tiêu của mình, hay đang phản hồi lại áp lực từ người khác?&quot; Câu hỏi này sẽ giúp bạn phân biệt rõ P1/P2 và P3."
                                       FontSize="12" Foreground="#374151" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
