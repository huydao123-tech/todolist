<UserControl x:Class="TodoList.Views.SurpriseTaskDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance viewmodels:SurpriseTaskDialogViewModel}"
             Background="White">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề khích lệ -->
        <TextBlock Grid.Row="0" Text="CHỈ CẦN TẬP TRUNG VÀO VIỆC NÀY THÔI!" 
                   FontSize="18" FontWeight="Bold" Foreground="#DC2626" 
                   HorizontalAlignment="Center" Margin="0,0,0,30" TextAlignment="Center"/>

        <!-- Tên công việc (FOCUS) -->
        <TextBlock Grid.Row="1" Text="{Binding CurrentSurpriseTask.Title}" 
                   FontSize="36" FontWeight="Black" Foreground="#1F2024" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   TextAlignment="Center" TextWrapping="Wrap" MaxWidth="500"/>

        <!-- Các nút bấm -->
        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,40,0,0">
            <!-- Nút siêu to khổng lồ: Làm xong rồi -->
            <Button Command="{Binding MarkAsDoneCommand}"
                    Background="#10B981" BorderBrush="#10B981" Foreground="White"
                    FontSize="20" FontWeight="Bold" Padding="30,15" Height="60"
                    materialDesign:ButtonAssist.CornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="28" Height="28" Margin="0,0,10,0"/>
                    <TextBlock Text="Đã Làm Xong!" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            
            <!-- Nút nhỏ: Đổi việc khác -->
            <Button Command="{Binding RollAgainCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="#6B7280" FontSize="14" Margin="0,15,0,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DiceMultiple" Width="18" Height="18" Margin="0,0,8,0"/>
                    <TextBlock Text="Cái khác đi... (Bốc lại)"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
