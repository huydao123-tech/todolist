<UserControl x:Class="TodoList.Views.CreateTaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:TodoList.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewmodels:CreateTaskViewModel}"
             d:DesignHeight="800" d:DesignWidth="950">
    <UserControl.Resources>
        <!-- Style nút chọn thứ dạng vòng tròn -->
        <Style x:Key="DayToggleStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Width="52" Height="52" CornerRadius="26"
                                Background="#F0F1F5" BorderThickness="0" Cursor="Hand">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="DayTxt" Text="{TemplateBinding Tag}"
                                           FontSize="9" FontWeight="Bold" Foreground="#8B8D98"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="NumTxt" Text="{TemplateBinding Content}"
                                           FontSize="15" FontWeight="Bold" Foreground="#1F2024"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"     Property="Background" Value="#5E40DF"/>
                                <Setter TargetName="DayTxt" Property="Foreground" Value="#C4B5FD"/>
                                <Setter TargetName="NumTxt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0DDF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="{Binding PageTitle}" FontSize="32" FontWeight="Bold" Foreground="#1F2024"/>
                <TextBlock Text="{Binding PageSubtitle}" FontSize="14" Foreground="#8B8D98" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Card Form -->
            <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="30" BorderBrush="#E2E8F0" BorderThickness="1"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Width="640">

                <StackPanel>
                    <!-- ── Task Title ── -->
                    <TextBlock Text="TASK TITLE" FontSize="11" FontWeight="Bold"
                               Foreground="#8B8D98" Margin="0,0,0,6"/>
                    <TextBox materialDesign:HintAssist.Hint="What do you need to do?"
                             Text="{Binding TaskTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             FontSize="15" Margin="0,0,0,28"/>

                    <!-- ── Description ── -->
                    <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="Bold"
                               Foreground="#8B8D98" Margin="0,0,0,6"/>
                    <TextBox materialDesign:HintAssist.Hint="Add more details (optional)"
                             Text="{Binding TaskDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" MinLines="3" MaxLines="5"
                             FontSize="14" Margin="0,0,0,30"/>

                    <!-- ── Chọn thứ trong tuần ── -->
                    <TextBlock Text="SCHEDULE FOR DAY OF WEEK" FontSize="11" FontWeight="Bold"
                               Foreground="#8B8D98" Margin="0,0,0,14"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <RadioButton Style="{StaticResource DayToggleStyle}" GroupName="DayGroup"
                                     Tag="MON" Content="2"
                                     IsChecked="{Binding SelectedDayOfWeek,
                                         Converter={StaticResource IntEqualConverter}, ConverterParameter=0}"/>
                        <RadioButton Style="{StaticResource DayToggleStyle}" GroupName="DayGroup"
                                     Tag="TUE" Content="3"
                                     IsChecked="{Binding SelectedDayOfWeek,
                                         Converter={StaticResource IntEqualConverter}, ConverterParameter=1}"/>
                        <RadioButton Style="{StaticResource DayToggleStyle}" GroupName="DayGroup"
                                     Tag="WED" Content="4"
                                     IsChecked="{Binding SelectedDayOfWeek,
                                         Converter={StaticResource IntEqualConverter}, ConverterParameter=2}"/>
                        <RadioButton Style="{StaticResource DayToggleStyle}" GroupName="DayGroup"
                                     Tag="THU" Content="5"
                                     IsChecked="{Binding SelectedDayOfWeek,
                                         Converter={StaticResource IntEqualConverter}, ConverterParameter=3}"/>
                        <RadioButton Style="{StaticResource DayToggleStyle}" GroupName="DayGroup"
                                     Tag="FRI" Content="6"
                                     IsChecked="{Binding SelectedDayOfWeek,
                                         Converter={StaticResource IntEqualConverter}, ConverterParameter=4}"/>
                        <RadioButton Style="{StaticResource DayToggleStyle}" GroupName="DayGroup"
                                     Tag="SAT" Content="7"
                                     IsChecked="{Binding SelectedDayOfWeek,
                                         Converter={StaticResource IntEqualConverter}, ConverterParameter=5}"/>
                        <RadioButton Style="{StaticResource DayToggleStyle}" GroupName="DayGroup"
                                     Tag="SUN" Content="CN"
                                     IsChecked="{Binding SelectedDayOfWeek,
                                         Converter={StaticResource IntEqualConverter}, ConverterParameter=6}"/>
                    </StackPanel>

                    <!-- ── Chọn Giờ & Phút ── -->
                    <TextBlock Text="TIME" FontSize="11" FontWeight="Bold"
                               Foreground="#8B8D98" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Start Time -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start Time" FontSize="12" Foreground="#8B8D98" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Hours}" SelectedItem="{Binding SelectedHour}" Style="{StaticResource MaterialDesignComboBox}" FontSize="15" FontWeight="SemiBold">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat='{}{0:D2}'}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Column="1" Text=":" FontSize="20" FontWeight="Bold" Foreground="#5E40DF" VerticalAlignment="Bottom" Margin="8,0,8,4"/>
                                <ComboBox Grid.Column="2" ItemsSource="{Binding Minutes}" SelectedItem="{Binding SelectedMinute}" Style="{StaticResource MaterialDesignComboBox}" FontSize="15" FontWeight="SemiBold">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat='{}{0:D2}'}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- End Time -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="End Time" FontSize="12" Foreground="#8B8D98" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Hours}" SelectedItem="{Binding SelectedEndHour}" Style="{StaticResource MaterialDesignComboBox}" FontSize="15" FontWeight="SemiBold">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat='{}{0:D2}'}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Column="1" Text=":" FontSize="20" FontWeight="Bold" Foreground="#5E40DF" VerticalAlignment="Bottom" Margin="8,0,8,4"/>
                                <ComboBox Grid.Column="2" ItemsSource="{Binding Minutes}" SelectedItem="{Binding SelectedEndMinute}" Style="{StaticResource MaterialDesignComboBox}" FontSize="15" FontWeight="SemiBold">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat='{}{0:D2}'}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- ── Priority ── -->
                    <TextBlock Text="PRIORITY" FontSize="11" FontWeight="Bold"
                               Foreground="#8B8D98" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,36">
                        <!-- High -->
                        <RadioButton GroupName="PriorityGroup"
                                     IsChecked="{Binding SelectedPriority,
                                         Converter={StaticResource StringEqualConverter}, ConverterParameter=High}"
                                     Margin="0,0,10,0">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Bd" Padding="18,9" CornerRadius="20"
                                            Background="#FEE2E2" BorderThickness="1.5" BorderBrush="#FECACA" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="Dot" Width="8" Height="8" Fill="#DC2626"
                                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                                            <TextBlock x:Name="Lbl" Text="High" FontSize="13" FontWeight="Bold"
                                                       Foreground="#DC2626" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd"  Property="Background"   Value="#DC2626"/>
                                            <Setter TargetName="Bd"  Property="BorderBrush"  Value="#DC2626"/>
                                            <Setter TargetName="Lbl" Property="Foreground"   Value="White"/>
                                            <Setter TargetName="Dot" Property="Fill"         Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>

                        <!-- Medium -->
                        <RadioButton GroupName="PriorityGroup"
                                     IsChecked="{Binding SelectedPriority,
                                         Converter={StaticResource StringEqualConverter}, ConverterParameter=Medium}"
                                     Margin="0,0,10,0">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Bd" Padding="18,9" CornerRadius="20"
                                            Background="#FFF3CD" BorderThickness="1.5" BorderBrush="#FDE68A" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="Dot" Width="8" Height="8" Fill="#D97706"
                                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                                            <TextBlock x:Name="Lbl" Text="Medium" FontSize="13" FontWeight="Bold"
                                                       Foreground="#D97706" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd"  Property="Background"  Value="#D97706"/>
                                            <Setter TargetName="Bd"  Property="BorderBrush" Value="#D97706"/>
                                            <Setter TargetName="Lbl" Property="Foreground"  Value="White"/>
                                            <Setter TargetName="Dot" Property="Fill"        Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>

                        <!-- Low -->
                        <RadioButton GroupName="PriorityGroup"
                                     IsChecked="{Binding SelectedPriority,
                                         Converter={StaticResource StringEqualConverter}, ConverterParameter=Low}">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Bd" Padding="18,9" CornerRadius="20"
                                            Background="#D1FAE5" BorderThickness="1.5" BorderBrush="#A7F3D0" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="Dot" Width="8" Height="8" Fill="#059669"
                                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                                            <TextBlock x:Name="Lbl" Text="Low" FontSize="13" FontWeight="Bold"
                                                       Foreground="#059669" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd"  Property="Background"  Value="#059669"/>
                                            <Setter TargetName="Bd"  Property="BorderBrush" Value="#059669"/>
                                            <Setter TargetName="Lbl" Property="Foreground"  Value="White"/>
                                            <Setter TargetName="Dot" Property="Fill"        Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>

                    <!-- ── Actions ── -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding CancelCommand}"
                                Content="Cancel"
                                Foreground="#8B8D98" BorderBrush="#D1D5DB"
                                Margin="0,0,15,0" Width="100" Height="42"/>
                        <Button Background="#5E40DF" Foreground="White" BorderThickness="0"
                                Command="{Binding SaveTaskCommand}"
                                Content="{Binding SubmitButtonText}" Width="130" Height="42"
                                materialDesign:ButtonAssist.CornerRadius="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
